aws_region       = "us-west-2"
project_name     = "poe"
environment      = "prod"

domain_name      = "example.com"
hosted_zone_id   = "Z1234567890ABCDE"
app_subdomain    = "poe"
origin_subdomain = "poe-origin"

instance_type    = "t3.small"
app_image        = "ghcr.io/sam/poe:latest"

sqlite_ebs_size_gb = 20
sqlite_ebs_type    = "gp3"
sqlite_device_name = "/dev/sdf"

# Optional: set if you want SSH access.
enable_ssh_ingress = false
ssh_key_name       = null
ssh_ingress_cidrs  = []

# Optional: allow direct app access from trusted CIDRs (for smoke tests).
additional_app_ingress_cidrs = []

tags = {
  Owner = "platform-team"
}
